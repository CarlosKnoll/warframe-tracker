{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warframe Arcane Tracker",
  "version": "2.3.0",
  "identifier": "com.warframe.arcane-tracker",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "upgradeCode": "49d0cb85-55db-4e7c-8379-95b444f35f65"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2MkNGNzEzQTBEODM0OTUKUldTVk5OaWdFL2NzbHNkUHNxL0ErUDY4cC9CQzk2RE1WU2kwQnIzMnczTlM0Wmo0dHZ5UmZCREsK",
      "endpoints": [
        "https://github.com/CarlosKnoll/warframe-tracker/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Warframe Arcane Tracker",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "label": "main"
      },
      {
        "title": "Checking for updates...",
        "width": 420,
        "height": 240,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "label": "updater",
        "url": "updater.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://raw.githubusercontent.com https://api.warframe.market;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  }
}