{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warframe Arcane Tracker",
  "version": "0.1.0",
  "identifier": "com.warframe.arcane-tracker",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Warframe Arcane Tracker",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://raw.githubusercontent.com;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  }
}